<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    tools:context=".PostAdFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create a New Listing"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_light_gray"
            android:layout_marginBottom="24dp"
            android:layout_gravity="center_horizontal" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/form_background_dark"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="What are you listing?"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_light_gray"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/listingTypeRadioGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/tradeTypeSell"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Item for Sale/Buy"
                        android:textColor="@color/text_light_gray"
                        android:buttonTint="@color/primary_color_accent"
                        android:checked="true"
                        android:layout_marginEnd="16dp"/>

                    <RadioButton
                        android:id="@+id/rentalType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="A Rental"
                        android:textColor="@color/text_light_gray"
                        android:buttonTint="@color/primary_color_accent"/>
                </RadioGroup>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/sell_buy_form_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rental_form_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/form_background_dark"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Property Details"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_light_gray"
                        android:layout_marginBottom="16dp" />

                    <Spinner
                        android:id="@+id/propertyTypeSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/background_dark"
                        android:padding="12dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/rentalRoomsEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Number of Rooms"
                            android:inputType="number"
                            android:textColor="@color/text_light_gray"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/rentalDescriptionEditText"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:gravity="top"
                            android:hint="Short Description"
                            android:inputType="textMultiLine"
                            android:textColor="@color/text_light_gray"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/rentalRulesEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Rules/Restrictions (e.g., No pets)"
                            android:inputType="text"
                            android:textColor="@color/text_light_gray"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/form_background_dark"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Location"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_light_gray"
                        android:layout_marginBottom="16dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/rentalCityEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="City/Town"
                            android:inputType="text"
                            android:textColor="@color/text_light_gray"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/rentalDistrictEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="District"
                            android:inputType="text"
                            android:textColor="@color/text_light_gray"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/rentalLocationDescEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Specific Location (e.g., Near the market)"
                            android:inputType="text"
                            android:textColor="@color/text_light_gray"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/form_background_dark"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rent Details"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_light_gray"
                        android:layout_marginBottom="16dp" />
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/rentalRentEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Monthly Rent"
                            android:inputType="numberDecimal"
                            android:textColor="@color/text_light_gray"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <RadioGroup
                        android:id="@+id/rentalPriceTypeRadioGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">
                        <RadioButton
                            android:id="@+id/rentalPriceFixed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fixed"
                            android:textColor="@color/text_light_gray"
                            android:buttonTint="@color/primary_color_accent"
                            android:checked="true"/>
                        <RadioButton
                            android:id="@+id/rentalPriceNegotiable"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Negotiable"
                            android:textColor="@color/text_light_gray"
                            android:buttonTint="@color/primary_color_accent"
                            android:layout_marginStart="16dp"/>
                    </RadioGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/form_background_dark"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Contact Information"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_light_gray"
                        android:layout_marginBottom="16dp" />
                    <RadioGroup
                        android:id="@+id/landlordTypeRadioGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">
                        <RadioButton
                            android:id="@+id/landlordTypeLandlord"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="I am the Landlord"
                            android:textColor="@color/text_light_gray"
                            android:buttonTint="@color/primary_color_accent"
                            android:checked="true"/>
                        <RadioButton
                            android:id="@+id/landlordTypeAgent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="I am an Agent"
                            android:textColor="@color/text_light_gray"
                            android:buttonTint="@color/primary_color_accent"
                            android:layout_marginStart="16dp"/>
                    </RadioGroup>
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/landlordNameEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Full Name"
                            android:inputType="textPersonName"
                            android:textColor="@color/text_light_gray"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/landlordPhoneEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Phone Number"
                            android:inputType="phone"
                            android:textColor="@color/text_light_gray"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/landlordEmailEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Email Address"
                            android:inputType="textEmailAddress"
                            android:textColor="@color/text_light_gray"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/landlordWhatsappEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="WhatsApp Number (Optional)"
                            android:inputType="phone"
                            android:textColor="@color/text_light_gray"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/form_background_dark"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Upload Photos (up to 10)"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_light_gray"
                        android:layout_marginBottom="16dp" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <LinearLayout
                            android:id="@+id/rentalImageContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="80dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <ImageView
                                android:id="@+id/addRentalPhotoButton"
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:src="@drawable/ic_add_photo"
                                android:background="@drawable/rounded_profile_pic"
                                android:scaleType="centerCrop"/>
                        </LinearLayout>
                    </HorizontalScrollView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/postAdButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Post Listing"
                android:textColor="@color/black"
                android:backgroundTint="@color/primary_color_accent"
                android:padding="16dp"
                app:cornerRadius="12dp" />
            <ProgressBar
                android:id="@+id/postAdProgressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:indeterminateTint="@color/black"/>
        </FrameLayout>

    </LinearLayout>
</ScrollView>