<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.LonyiTrade" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/background_light</item>
        <item name="colorPrimaryVariant">@color/background_light</item>
        <item name="colorOnPrimary">@color/text_dark</item>
        <item name="colorSecondary">@color/primary_color_accent</item>
        <item name="colorSecondaryVariant">@color/primary_color_accent</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/background_light</item>
        <item name="android:navigationBarColor">@color/background_light</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o">true</item>
    </style>

    <style name="Widget.App.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconSize">@dimen/bottom_nav_icon_size</item>
        <item name="itemTextAppearanceActive">@style/Widget.App.BottomNavigationView.TextAppearance</item>
        <item name="itemTextAppearanceInactive">@style/Widget.App.BottomNavigationView.TextAppearance</item>
    </style>

    <style name="Widget.App.BottomNavigationView.TextAppearance" parent="">
        <item name="android:textSize">@dimen/bottom_nav_text_size</item>
    </style>

    <style name="Widget.App.TextInputLayout" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@color/form_background_light</item>
        <item name="hintTextColor">@color/text_dark</item>
        <item name="android:textColorHint">@color/text_dark</item>
        <item name="boxStrokeColor">@color/text_dark</item>
        <item name="boxStrokeWidth">1dp</item>
    </style>
</resources>